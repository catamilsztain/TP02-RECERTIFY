@{
    ViewData["Title"] = "Home Page";
}


<h1>Formulario</h1>
<form action = '@Url.Action("GenerarReceta", "Home")' method = "post" enctype = "multipart/form-data">

    Nombre: <input type = "text" name="Nombre"/><br/>
    Fecha de nacimiento: <input type = "date" name="FechaNacimiento"/><br/>
    Tipo de Comida: <input type = "radio" name="TipoComida" value="Caliente"> Caliente
                    <input type = "radio" name="TipoComida" value="Fría"> Fría <br/>
    Presupuesto: <input type = "number" name="PresupuestoDisp" min = "1" /><br/>
    Cantidad de personas: <input type = "number" name="CantPersonas" min = "1" max = "20" /><br/>
    <button type = "submit"> Enviar </button>
</form>
